{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/api/api.php",
            "dest": "/api/api.php"
        },
        {
            "src": "/api/(.*)\\.php",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}